page {
  background: #120d09;
  color: #f3dfbc;
}

.zen-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.bg-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.95;
}

.content {
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 136rpx);
  padding: 56rpx 30rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.top-area {
  text-align: center;
  margin-top: 16rpx;
}

.title {
  font-size: 54rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #f4e4c5;
}

.merit {
  margin-top: 10rpx;
  font-size: 50rpx;
  font-weight: 700;
  color: #ffd38c;
}

.main-stage {
  flex: 1;
  min-height: 560rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hitbox {
  width: 680rpx;
  height: 680rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.target-scale-layer {
  width: 620rpx;
  height: 520rpx;
  transform-origin: 50% 62%;
  transition: transform 180ms ease-out;
  position: relative;
}

.target-hit-layer {
  width: 100%;
  height: 100%;
  transform-origin: 50% 62%;
  position: relative;
}

.target-hitting {
  animation: hitPulse 180ms cubic-bezier(0.2, 0.9, 0.3, 1);
}

.target-image {
  width: 100%;
  height: 100%;
}

.beads-ring {
  position: absolute;
  inset: 0;
}

.bead-item {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 28%, #ffe3b8 0%, #d69449 48%, #7f4f27 100%);
  box-shadow:
    inset 0 0 8rpx rgba(255, 229, 186, 0.4),
    0 3rpx 7rpx rgba(39, 23, 9, 0.36);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: left 240ms cubic-bezier(0.2, 0.75, 0.3, 1), top 240ms cubic-bezier(0.2, 0.75, 0.3, 1);
}

.bead-fo {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(77, 45, 18, 0.92);
  text-shadow: 0 1rpx 1rpx rgba(255, 240, 207, 0.35);
}

.target-image-hitting {
  animation: imageFlash 180ms ease-out;
}

.hit-glow {
  position: absolute;
  left: 50%;
  top: 52%;
  width: 260rpx;
  height: 160rpx;
  margin-left: -130rpx;
  margin-top: -80rpx;
  background: radial-gradient(ellipse at center, rgba(255, 220, 150, 0.38) 0%, rgba(255, 220, 150, 0) 72%);
  opacity: 0;
  pointer-events: none;
}

.hit-glow-active {
  animation: hitGlow 180ms ease-out;
}

.hit-ripple {
  position: absolute;
  left: 50%;
  top: 56%;
  width: 220rpx;
  height: 220rpx;
  margin-left: -110rpx;
  margin-top: -110rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 215, 154, 0);
  pointer-events: none;
}

.hit-ripple-active {
  animation: ripple 220ms ease-out;
}

.buddha-rise {
  position: absolute;
  left: 50%;
  bottom: 120rpx;
  width: 240rpx;
  height: 320rpx;
  margin-left: -120rpx;
  opacity: 0;
  pointer-events: none;
}

.buddha-rise-active {
  animation: buddhaRise 1.45s ease-out forwards;
}

.float-text {
  position: absolute;
  top: 24%;
  color: #ffd79a;
  font-size: 46rpx;
  font-weight: 700;
  text-shadow: 0 4rpx 10rpx rgba(49, 29, 8, 0.6);
  pointer-events: none;
  animation: floatUp 680ms cubic-bezier(0.19, 0.95, 0.27, 0.99) forwards;
}

.settings-toggle {
  margin-bottom: 14rpx;
  border-radius: 20rpx;
  background: rgba(34, 24, 15, 0.72);
  border: 1rpx solid rgba(232, 196, 138, 0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  color: #f0d5ac;
  font-size: 28rpx;
}

.arrow {
  font-size: 24rpx;
  color: #e3bf8b;
}

.settings {
  border-radius: 24rpx;
  background: rgba(28, 20, 13, 0.86);
  border: 1rpx solid rgba(232, 196, 138, 0.18);
  padding: 8rpx 24rpx 22rpx;
}

.setting-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(232, 196, 138, 0.14);
  font-size: 28rpx;
  color: #f0d5ac;
}

.setting-row:last-of-type {
  border-bottom: 0;
}

.picker-value {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(198, 138, 68, 0.22);
  color: #f1d2a6;
  font-size: 26rpx;
}

.reset-btn {
  margin-top: 18rpx;
  background: linear-gradient(180deg, #f3c67f 0%, #b67835 100%);
  color: #291707;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 2.2;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  height: 128rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  background: rgba(8, 6, 4, 0.96);
  border-top: 1rpx solid rgba(232, 196, 138, 0.12);
  padding-top: 12rpx;
  box-sizing: border-box;
}

.nav-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #a48863;
}

.nav-icon {
  width: 38rpx;
  height: 38rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid currentColor;
}

.nav-icon-muyu {
  border-radius: 24rpx 24rpx 24rpx 8rpx;
  transform: rotate(-14deg);
}

.nav-icon-beads {
  border-radius: 50%;
  box-shadow: -20rpx 0 0 -4rpx currentColor, 20rpx 0 0 -4rpx currentColor;
}

.nav-icon-bell {
  border-radius: 18rpx 18rpx 12rpx 12rpx;
  border-bottom-width: 6rpx;
}

.nav-label {
  font-size: 24rpx;
}

.nav-item-active {
  color: #f0d1a0;
}

@keyframes floatUp {
  0% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(0.94);
  }

  100% {
    opacity: 0;
    transform: translate3d(var(--driftX), -130rpx, 0) scale(1.05);
  }
}

@keyframes hitPulse {
  0% {
    transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
  }

  35% {
    transform: translate3d(-14rpx, 12rpx, 0) scale(0.89) rotate(-2.2deg);
  }

  70% {
    transform: translate3d(0, -4rpx, 0) scale(1.03) rotate(1.1deg);
  }

  100% {
    transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
  }
}

@keyframes imageFlash {
  0% {
    filter: brightness(1) saturate(1);
  }

  35% {
    filter: brightness(1.26) saturate(1.2);
  }

  100% {
    filter: brightness(1) saturate(1);
  }
}

@keyframes ripple {
  0% {
    transform: scale(0.7);
    border-color: rgba(255, 215, 154, 0.45);
    opacity: 1;
  }

  100% {
    transform: scale(1.24);
    border-color: rgba(255, 215, 154, 0);
    opacity: 0;
  }
}

@keyframes hitGlow {
  0% {
    opacity: 0;
    transform: scale(0.85);
  }

  35% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(1.1);
  }
}


@keyframes buddhaRise {
  0% {
    opacity: 0;
    transform: translate3d(0, 40rpx, 0) scale(0.86);
    filter: brightness(1);
  }

  25% {
    opacity: 1;
    transform: translate3d(0, -40rpx, 0) scale(1.02);
    filter: brightness(1.2);
  }

  100% {
    opacity: 0;
    transform: translate3d(0, -440rpx, 0) scale(1.1);
    filter: brightness(1.32);
  }
}
